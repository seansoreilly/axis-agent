{
  "mcpServers": {
    "zapier": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-zapier"]
    },
    "trello": {
      "command": "node",
      "args": ["dist/trello-mcp-server.js"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--headless", "--browser", "chromium", "--viewport-size", "1280x720"]
    }
  }
}
