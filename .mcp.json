{
  "mcpServers": {
    "composio": {
      "type": "http",
      "url": "https://backend.composio.dev/mcp",
      "headers": {
        "x-api-key": "${COMPOSIO_API_KEY}"
      }
    },
    "trello": {
      "command": "node",
      "args": ["dist/trello-mcp-server.js"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--headless", "--browser", "chromium", "--viewport-size", "1280x720"]
    }
  }
}
