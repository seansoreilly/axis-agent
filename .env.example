# === Config (stays in .env on server) ===

# Gateway server port
PORT=8080

# Claude Agent SDK settings
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TURNS=25
CLAUDE_MAX_BUDGET_USD=5

# Working directory for Claude operations
CLAUDE_WORK_DIR=/home/ubuntu/workspace

# Memory storage directory
MEMORY_DIR=/home/ubuntu/.claude-agent/memory

# Owner name for voice call introductions (e.g. "Sean O'Reilly")
# OWNER_NAME=Sean O'Reilly

# Gateway API token for authenticating HTTP endpoints (optional — no auth if unset)
# GATEWAY_API_TOKEN=

# === Secrets (managed via Bitwarden — see scripts/sync-secrets.sh) ===
# Each secret is stored as an individual Bitwarden secure note in the
# "claude-agent-lightsail" folder. sync-secrets.sh looks up each entry
# by name and merges them into this .env file. Do NOT manually edit these.
#
# Vault entry name             → Env var injected
# telegram-bot-token           → TELEGRAM_BOT_TOKEN
# telegram-allowed-users       → TELEGRAM_ALLOWED_USERS
# gh-token                     → GH_TOKEN
# ical-url                     → ICAL_URL
# google-maps-api-key          → GOOGLE_MAPS_API_KEY
# facebook-app-id              → FACEBOOK_APP_ID
# facebook-app-secret          → FACEBOOK_APP_SECRET
# facebook-page-id             → FACEBOOK_PAGE_ID
# facebook-page-token-env      → FACEBOOK_PAGE_TOKEN
# composio-api-key             → COMPOSIO_API_KEY
# trello-api-key               → TRELLO_API_KEY
# trello-api-token             → TRELLO_API_TOKEN
# owntracks-token              → OWNTRACKS_TOKEN
# vapi-api-key                 → VAPI_API_KEY
# vapi-phone-number-id         → VAPI_PHONE_NUMBER_ID
# cartesia-voice-id            → CARTESIA_VOICE_ID
#
# Auth: OAuth credentials in ~/.claude/.credentials.json (auto-refreshed by SDK)
# No ANTHROPIC_API_KEY needed — uses Max subscription via OAuth
